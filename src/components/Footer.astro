---
import {
  Star,
  MapPin,
  Phone,
  Mail,
  Facebook,
  Instagram,
  Youtube,
  Linkedin,
  ArrowRight,
} from "@lucide/astro";
---

<footer class="bg-[#1a1a1a] py-12 text-white">
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-4 sm:px-6 md:grid-cols-4 lg:px-8"
  >
    <!-- Column 1: Info -->
    <div>
      <div class="mb-4 flex items-center">
        <div class="mr-2 rounded bg-teal-500 px-3 py-2 font-bold text-white">
          5D
        </div>
        <div>
          <h3 class="text-xl font-bold">5 Direcciones</h3>
          <p class="text-sm text-gray-400">Estrategia Empresarial</p>
        </div>
      </div>
      <p class="mb-6 text-gray-400">
        Acompañamos a los empresarios en la consecución de sus objetivos
        empresariales, proporcionando soluciones integrales para el crecimiento
        de su negocio.
      </p>
      <div class="flex space-x-4">
        <a href="#" class="text-gray-400 transition-colors hover:text-white"
          ><Facebook class="h-6 w-6" /></a
        >
        <a href="#" class="text-gray-400 transition-colors hover:text-white"
          ><Instagram class="h-6 w-6" /></a
        >
        <a href="#" class="text-gray-400 transition-colors hover:text-white"
          ><Youtube class="h-6 w-6" /></a
        >
        <a href="#" class="text-gray-400 transition-colors hover:text-white"
          ><Linkedin class="h-6 w-6" /></a
        >
      </div>
    </div>

    <!-- Column 2: Services -->
    <div>
      <h3 class="mb-4 text-lg font-bold">Services</h3>
      <ul class="space-y-2">
        <li>
          <a
            href="#"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" /> Dirección Administrativa</a
          >
        </li>
        <li>
          <a
            href="#"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" /> Dirección Contable</a
          >
        </li>
        <li>
          <a
            href="#"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" /> Gestión de Proyectos</a
          >
        </li>
        <li>
          <a
            href="#"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" /> Talento Humano</a
          >
        </li>
        <li>
          <a
            href="#"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" /> Asesoría Legal</a
          >
        </li>
      </ul>
    </div>

    <!-- Column 3: Quick Links -->
    <div>
      <h3 class="mb-4 text-lg font-bold">Quick Links</h3>
      <ul class="space-y-2">
        <li>
          <a
            href="#inicio"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" />Inicio</a
          >
        </li>
        <li>
          <a
            href="#nosotros"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" />Nosotros</a
          >
        </li>
        <li>
          <a
            href="#servicios"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" />Servicios</a
          >
        </li>
        <li>
          <a
            href="#cursos"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" />Cursos</a
          >
        </li>
        <li>
          <a
            href="#blog"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" />Blog</a
          >
        </li>
        <li>
          <a
            href="#contacto"
            class="flex items-center text-gray-400 transition-colors hover:text-white"
            ><ArrowRight class="mr-2 h-4 w-4" />Contacto</a
          >
        </li>
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div>
      <h3 class="mb-4 text-lg font-bold">Contact</h3>
      <div class="mb-4 space-y-3">
        <div class="flex items-center text-gray-400">
          <MapPin class="mr-3 h-5 w-5 text-teal-500" />
          <span>Medellín, Antioquia<br />Colombia</span>
        </div>
        <div class="flex items-center text-gray-400">
          <Phone class="mr-3 h-5 w-5 text-teal-500" />
          <span>(+57) 301 393 6616</span>
        </div>
        <div class="flex items-center text-gray-400">
          <Mail class="mr-3 h-5 w-5 text-teal-500" />
          <span>info@5direcciones.com</span>
        </div>
      </div>
      <a
        href="https://wa.me/573013936616"
        class="btn btn-default btn-sm mt-2 w-full border-white bg-white text-black hover:bg-gray-100 hover:text-black sm:w-auto"
      >
        Consulta por WhatsApp
      </a>
    </div>
  </div>

  <!-- Bottom Section -->
  <div
    class="mx-auto mt-12 max-w-7xl border-t border-gray-800 px-4 pt-8 sm:px-6 lg:px-8"
  >
    <div class="flex flex-col items-center justify-between md:flex-row">
      <div class="mb-4 text-sm text-gray-400 md:mb-0">
        <p>&copy; 2026 5 Direcciones. Todos los derechos reservados.</p>
      </div>
      <div class="flex space-x-6 text-sm">
        <a href="#" class="text-gray-400 transition-colors hover:text-white"
          >Política de Privacidad</a
        >
        <a href="#" class="text-gray-400 transition-colors hover:text-white"
          >Términos de Uso</a
        >
      </div>
    </div>
  </div>
</footer>
