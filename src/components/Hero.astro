---
import { Briefcase, Star, BadgeCheck, Users, ArrowRight } from '@lucide/astro';
import { Button } from './ui/button.tsx';
import { Badge } from './ui/badge.tsx';
---

<section class="relative bg-cover bg-center h-[800px] flex items-center justify-center text-white" style="background-image: url('/Hero.png');">
  <div class="absolute inset-0 bg-linear-to-r from-teal-600 via-teal-500 to-green-500 opacity-55"></div>
  <div class="relative z-10 text-center px-6 max-w-6xl mx-auto">

    <!-- Badge -->
    <Badge class="bg-white bg-opacity-20 text-black text-sm font-semibold px-4 py-4 mb-6">
      <Star class="w-6 h-6 mr-2" />
      Más de 500 empresas confían en nosotros
    </Badge>

    <!-- Main Heading -->
    <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
      Impulsa tu empresa con<br/>
      <span class="text-white">5 Direcciones</span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl md:text-2xl mb-8 max-w-3xl mx-auto text-white text-opacity-90">
      Acompañamos a empresarios en la consecución de sus objetivos empresariales con soluciones integrales y especializadas.
    </p>

    <!-- Button -->
    <Button class="inline-flex items-center justify-center px-8 py-4 rounded-full text-black text-lg font-semibold bg-white bg-opacity-20 hover:bg-opacity-30 transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
      Consulta Gratuita
      <ArrowRight class="w-3 h-3 ml-2" />
    </Button>

    <!-- Statistics -->
    <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto">
      <div class="text-center">
        <div class="flex justify-center mb-2">
          <div class="h-12 flex items-center justify-center">
            <Briefcase class="w-8 h-8 text-white" />
          </div>
        </div>
        <p class="text-3xl font-bold">500+</p>
        <p class="text-sm text-white text-opacity-80">Empresas Asesoradas</p>
      </div>
      
      <div class="text-center">
        <div class="flex justify-center mb-2">
          <div class="h-12 flex items-center justify-center">
            <Star class="w-8 h-8 text-white" />         
          </div>
        </div>
        <p class="text-3xl font-bold">8+</p>
        <p class="text-sm text-white text-opacity-80">Años de Experiencia</p>
      </div>
      
      <div class="text-center">
        <div class="flex justify-center mb-2">
          <div class="h-12 flex items-center justify-center">
            <BadgeCheck class="w-8 h-8 text-white" />
          </div>
        </div>
        <p class="text-3xl font-bold">98%</p>
        <p class="text-sm text-white text-opacity-80">Satisfacción del Cliente</p>
      </div>
      
      <div class="text-center">
        <div class="flex justify-center mb-2">
          <div class="h-12 flex items-center justify-center">
            <Users class="w-8 h-8 text-white" />
          </div>
        </div>
        <p class="text-3xl font-bold">50+</p>
        <p class="text-sm text-white text-opacity-80">Profesionales Especializados</p>
      </div>
    </div>
  </div>
</section>
