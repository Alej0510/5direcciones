---
import { CircleCheck, ArrowRight } from "@lucide/astro";
import MaxWidthWrapper from "../MaxWidthWrapper.astro";

const features = [
    {
        title: "Experiencia Comprobada",
        description:
            "Más de 8 años asesorando empresas de diferentes sectores y tamaños con éxito sostenido.",
    },
    {
        title: "Enfoque Integral",
        description:
            "Cubrimos todas las áreas críticas para el éxito empresarial desde una visión 360°.",
    },
    {
        title: "Resultados Medibles",
        description: "98% de satisfacción del cliente y resultados tangibles en productividad y ahorro.",
    },
    {
        title: "Acompañamiento Personalizado",
        description:
            "Cada empresa recibe atención especializada y soluciones a medida de sus desafíos.",
    },
];

const stats = [
    { value: "500+", label: "Empresas Asesoradas", color: "text-primary" },
    { value: "98%", label: "Satisfacción", color: "text-cyan-600" },
    { value: "10+", label: "Profesionales", color: "text-primary" },
    { value: "8+", label: "Años Experiencia", color: "text-cyan-600" },
];
---

<section id="experience" class="relative py-24 lg:py-32 bg-background overflow-hidden">
  <MaxWidthWrapper>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <!-- Left Column: Content -->
      <div class="animate-fade-in-left">
        <span class="inline-flex items-center rounded-full bg-secondary px-4 py-1.5 text-xs font-bold tracking-wider uppercase text-secondary-foreground mb-6 border border-primary/10">
          ¿Por Qué Elegirnos?
        </span>
        
        <h2 class="text-4xl md:text-5xl font-black text-foreground mb-10 leading-tight tracking-tight">
          La Experiencia que tu <span class="text-primary italic font-serif">Empresa</span> Necesita
        </h2>

        <div class="space-y-8 mb-12">
          {features.map((feature, index) => (
            <div 
              class="group flex gap-5 items-start animate-on-scroll"
              style={`animation-delay: ${index * 150}ms`}
            >
              <div class="mt-1 shrink-0">
                <CircleCheck class="w-7 h-7 text-primary group-hover:scale-110 transition-transform duration-300" stroke-width={2.5} />
              </div>
              <div>
                <h3 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
                  {feature.title}
                </h3>
                <p class="text-muted-foreground/90 leading-relaxed font-medium">
                  {feature.description}
                </p>
              </div>
            </div>
          ))}
        </div>

        <a 
          href="/#contacto" 
          class="group inline-flex items-center justify-center gap-3 bg-linear-to-r from-primary to-[#17b0cf] text-white font-bold py-4 px-10 rounded-2xl shadow-xl shadow-primary/20 hover:shadow-2xl hover:shadow-primary/30 hover:-translate-y-1 transition-all duration-300"
        >
          Agenda una Consulta
          <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>

      <!-- Right Column: Stats Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 relative animate-fade-in-right">
        <!-- Abstract Decorations -->
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl -z-10"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-secondary/40 rounded-full blur-3xl -z-10"></div>

        {stats.map((stat, index) => (
          <div 
            class="group bg-white p-10 rounded-[2.5rem] border border-border/50 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 flex flex-col items-center text-center"
            style={`animation-delay: ${index * 150}ms`}
          >
            <div class={`w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-6 transition-all duration-500`}>
               <span class={`text-4xl md:text-5xl font-black ${stat.color} tracking-tighter`}>
                 {stat.value}
               </span>
            </div>
            <div class="text-sm font-bold text-muted-foreground uppercase tracking-widest leading-tight">
              {stat.label}
            </div>
            
            <!-- Subtle interactive accent -->
            <div class="mt-6 w-8 h-1 bg-border group-hover:w-16 group-hover:bg-primary transition-all duration-500 rounded-full"></div>
          </div>
        ))}
      </div>

    </div>
  </MaxWidthWrapper>
</section>

<style>
  @keyframes fade-in-left {
    from { opacity: 0; transform: translateX(-30px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes fade-in-right {
    from { opacity: 0; transform: translateX(30px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .animate-fade-in-left {
    animation: fade-in-left 1s ease-out forwards;
  }
  .animate-fade-in-right {
    animation: fade-in-right 1s ease-out forwards;
  }
  
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    animation: slide-up 0.8s ease-out forwards;
  }
  
  @keyframes slide-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
