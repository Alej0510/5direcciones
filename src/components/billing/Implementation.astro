---
import MaxWidthWrapper from "../MaxWidthWrapper.astro";
---

<section class="bg-background relative py-10 pb-20">
    <MaxWidthWrapper>
        <div class="mb-16 text-center">
            <div
                class="mb-6 inline-flex items-center rounded-full border border-[#17b0cf]/20 bg-[#17b0cf]/10 px-3 py-1 text-xs font-semibold tracking-wider text-[#17b0cf] uppercase"
            >
                Proceso de Implementación
            </div>
            <h2
                class="text-foreground mb-4 text-3xl font-bold tracking-tight sm:text-4xl"
            >
                Implementación Rápida y Sencilla
            </h2>
            <p class="text-muted-foreground text-lg">
                En solo 4 pasos tendrás tu sistema de facturación electrónica
                funcionando
            </p>
        </div>

        <div class="relative mx-auto mt-16 grid max-w-5xl gap-8 lg:grid-cols-4">
            <!-- Step 1 -->
            <div class="relative flex flex-col items-center text-center">
                <div
                    class="bg-primary shadow-primary/25 z-10 mb-6 flex h-14 w-14 items-center justify-center rounded-full text-xl font-bold text-white shadow-lg"
                >
                    1
                </div>
                <h3 class="text-foreground mb-3 text-lg font-bold">
                    Configuración Inicial
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                    Configuramos tu empresa en nuestra plataforma según los
                    requerimientos de la DIAN.
                </p>
            </div>

            <!-- Step 2 -->
            <div class="relative flex flex-col items-center text-center">
                <div
                    class="z-10 mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-[#17b0cf] text-xl font-bold text-white shadow-lg shadow-[#17b0cf]/25"
                >
                    2
                </div>
                <h3 class="text-foreground mb-3 text-lg font-bold">
                    Capacitación
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                    Entrenamos a tu equipo para usar eficientemente todas las
                    funcionalidades.
                </p>
            </div>

            <!-- Step 3 -->
            <div class="relative flex flex-col items-center text-center">
                <div
                    class="bg-primary shadow-primary/25 z-10 mb-6 flex h-14 w-14 items-center justify-center rounded-full text-xl font-bold text-white shadow-lg"
                >
                    3
                </div>
                <h3 class="text-foreground mb-3 text-lg font-bold">
                    Migración de Datos
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                    Transferimos tu información existente de manera segura y
                    ordenada.
                </p>
            </div>

            <!-- Step 4 -->
            <div class="relative flex flex-col items-center text-center">
                <div
                    class="z-10 mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-[#17b0cf] text-xl font-bold text-white shadow-lg shadow-[#17b0cf]/25"
                >
                    4
                </div>
                <h3 class="text-foreground mb-3 text-lg font-bold">
                    Puesta en Marcha
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                    Activamos tu sistema y comenzamos la facturación
                    electrónica.
                </p>
            </div>
        </div>

        <div class="mt-20 flex justify-center">
            <a
                href="#contacto"
                class="from-primary inline-flex items-center justify-center rounded-xl bg-linear-to-r to-[#17b0cf] px-8 py-3.5 text-sm font-bold text-white shadow-lg transition-all hover:-translate-y-1 hover:opacity-90 hover:shadow-xl"
            >
                Cotiza con nosotros el proceso de implementación
            </a>
        </div>
    </MaxWidthWrapper>
</section>
