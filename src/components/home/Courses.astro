---
import { ArrowRight, MonitorPlay, Clock, Award } from "@lucide/astro";
import MaxWidthWrapper from "../MaxWidthWrapper.astro";

const features = [
  { icon: MonitorPlay, text: "Cursos especializados por categorías" },
  { icon: Award, text: "Certificación al completar módulos" },
  { icon: Clock, text: "Acceso 24/7 desde cualquier dispositivo" },
];
---

<section class="courses-section" id="cursos">
  <MaxWidthWrapper>
    <div class="courses-inner">
      <!-- Decorative blobs -->
      <div aria-hidden="true" class="blob blob-1"></div>
      <div aria-hidden="true" class="blob blob-2"></div>

      <div class="courses-content">
        <!-- Left: text -->
        <div class="courses-left">
          <!-- Eyebrow badge -->
          <div class="badge">
            <span class="badge-dot"></span>
            <span>🎓 Nueva Plataforma de Cursos</span>
          </div>

          <h2 class="courses-heading">
            Aprende y Capacita<br />
            <span class="courses-em">tu Equipo</span>
          </h2>

          <p class="courses-desc">
            Accede a nuestra plataforma de cursos especializados en todas las
            áreas empresariales. Formación práctica impartida por expertos.
          </p>

          <!-- Feature list -->
          <ul class="features-list">
            {
              features.map(({ icon: Icon, text }) => (
                <li class="feature-item">
                  <span class="feature-icon-wrap">
                    <Icon class="feature-icon" />
                  </span>
                  <span>{text}</span>
                </li>
              ))
            }
          </ul>

          <a href="#" class="courses-btn">
            Explorar Cursos
            <ArrowRight class="btn-arrow" />
          </a>
        </div>

        <!-- Right: image -->
        <div class="courses-right">
          <img
            src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=900&q=85&auto=format&fit=crop"
            alt="Capacitación empresarial"
            class="courses-img"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </MaxWidthWrapper>
</section>

<style>
  .courses-section {
    padding: 4rem 0;
  }

  .courses-inner {
    position: relative;
    overflow: hidden;
    border-radius: 2rem;
    background: linear-gradient(135deg, #0d3535 0%, #0a4a4a 45%, #0e5a50 100%);
    padding: 4rem 3rem;
  }

  /* Decorative blobs */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .blob-1 {
    width: 500px;
    height: 500px;
    top: -160px;
    right: -100px;
    background: color-mix(in srgb, var(--primary) 20%, transparent);
  }
  .blob-2 {
    width: 300px;
    height: 300px;
    bottom: -80px;
    left: 10%;
    background: color-mix(in srgb, #17b0cf 15%, transparent);
  }

  .courses-content {
    position: relative;
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .courses-inner {
      padding: 5rem 4rem;
    }
    .courses-content {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  /* ── Left column ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    padding: 0.375rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.5rem;
    backdrop-filter: blur(6px);
  }
  .badge-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.8);
    }
  }

  .courses-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .courses-em {
    background: linear-gradient(90deg, #5eead4, #a7f3d0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .courses-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    max-width: 28rem;
    margin-bottom: 2rem;
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.85);
  }
  .feature-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }
  .feature-icon {
    width: 1rem;
    height: 1rem;
    color: #5eead4;
  }

  .courses-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--primary);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    transition:
      background 0.25s,
      transform 0.25s,
      box-shadow 0.25s;
  }
  .courses-btn:hover {
    background: color-mix(in srgb, var(--primary) 85%, #fff);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--primary) 45%, transparent);
  }
  .btn-arrow {
    width: 1rem;
    height: 1rem;
    transition: transform 0.25s;
  }
  .courses-btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  /* ── Right column: image ── */
  .courses-right {
    opacity: 0;
    transform: translateY(24px) scale(0.97);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s,
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
  }
  .courses-right.in-view {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .courses-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    border-radius: 1.25rem;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.4);
    display: block;
  }

  /* Left entrance */
  .courses-left {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .courses-left.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add("in-view");
        observer.unobserve(entry.target);
      });
    },
    { threshold: 0.15 },
  );

  document
    .querySelectorAll(".courses-left, .courses-right")
    .forEach((el) => observer.observe(el));
</script>
