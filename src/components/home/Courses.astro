---
import { ArrowRight, MonitorPlay, Clock, Award } from "@lucide/astro";
import MaxWidthWrapper from "../MaxWidthWrapper.astro";

const features = [
  { icon: MonitorPlay, text: "Cursos especializados por categorías" },
  { icon: Award, text: "Certificación al completar módulos" },
  { icon: Clock, text: "Acceso 24/7 desde cualquier dispositivo" },
];
---

<section class="bg-background py-16" id="cursos">
  <MaxWidthWrapper>
    <div
      class="courses-inner relative overflow-hidden rounded-[2rem] p-8 lg:p-16"
      style="background: linear-gradient(135deg, #0d3535 0%, #0a4a4a 45%, #0e5a50 100%);"
    >
      <!-- Decorative blobs -->
      <div aria-hidden="true" class="blob blob-1"></div>
      <div aria-hidden="true" class="blob blob-2"></div>

      <div
        class="courses-content relative grid items-center gap-12 lg:grid-cols-2 lg:gap-16"
      >
        <!-- Left: text -->
        <div class="courses-left">
          <!-- Eyebrow badge -->
          <div
            class="courses-badge mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/[0.08] px-4 py-1.5 text-[0.8125rem] font-semibold text-white/90"
          >
            <span class="badge-dot"></span>
            <span>🎓 Nueva Plataforma de Cursos</span>
          </div>

          <h2
            class="courses-heading mb-5 leading-[1.1] font-bold tracking-[-0.02em] text-white"
          >
            Aprende y Capacita<br />
            <span class="courses-em">tu Equipo</span>
          </h2>

          <p class="mb-8 max-w-[28rem] text-base leading-[1.7] text-white/65">
            Accede a nuestra plataforma de cursos especializados en todas las
            áreas empresariales. Formación práctica impartida por expertos.
          </p>

          <!-- Feature list -->
          <ul class="m-0 mb-9 flex list-none flex-col gap-3.5 p-0">
            {
              features.map(({ icon: Icon, text }) => (
                <li class="flex items-center gap-3 text-[0.9375rem] text-white/85">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white/10">
                    <Icon class="h-4 w-4 text-[#5eead4]" />
                  </span>
                  <span>{text}</span>
                </li>
              ))
            }
          </ul>

          <a
            href="#"
            class="courses-btn bg-primary inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-[0.9375rem] font-semibold text-white no-underline"
          >
            Explorar Cursos
            <ArrowRight class="btn-arrow h-4 w-4" />
          </a>
        </div>

        <!-- Right: image -->
        <div class="courses-right">
          <img
            src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=900&q=85&auto=format&fit=crop"
            alt="Capacitación empresarial"
            class="block h-[420px] w-full rounded-[1.25rem] object-cover"
            style="box-shadow: 0 32px 80px rgba(0,0,0,0.4);"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </MaxWidthWrapper>
</section>

<style>
  /* Decorative blobs */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .blob-1 {
    width: 500px;
    height: 500px;
    top: -160px;
    right: -100px;
    background: color-mix(in srgb, var(--primary) 20%, transparent);
  }
  .blob-2 {
    width: 300px;
    height: 300px;
    bottom: -80px;
    left: 10%;
    background: color-mix(in srgb, #17b0cf 15%, transparent);
  }

  /* Badge styling */
  .courses-badge {
    position: relative;
    isolation: isolate;
  }
  .courses-badge::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: none;
  }

  /* Badge pulsing dot */
  .badge-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.8);
    }
  }

  /* Heading responsive size — clamp not available in Tailwind */
  .courses-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1.25rem;
  }

  /* Gradient text — requires vendor prefixes */
  .courses-em {
    background: linear-gradient(90deg, #5eead4, #a7f3d0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Button interactions */
  .courses-btn {
    transition:
      background 0.25s,
      transform 0.25s,
      box-shadow 0.25s;
  }
  .courses-btn:hover {
    background: color-mix(in srgb, var(--primary) 85%, #fff);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--primary) 45%, transparent);
  }
  .btn-arrow {
    transition: transform 0.25s;
  }
  .courses-btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  /* Scroll-reveal entrance animations */
  .courses-right {
    opacity: 0;
    transform: translateY(24px) scale(0.97);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s,
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
  }
  .courses-right.in-view {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .courses-left {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .courses-left.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add("in-view");
        observer.unobserve(entry.target);
      });
    },
    { threshold: 0.15 },
  );

  document
    .querySelectorAll(".courses-left, .courses-right")
    .forEach((el) => observer.observe(el));
</script>
