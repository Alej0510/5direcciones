---
import {
  LayoutDashboard,
  TrendingUp,
  Rocket,
  Users,
  Scale,
  ArrowRight,
  CheckCircle2,
  ChevronRight,
} from "@lucide/astro";
import MaxWidthWrapper from "../MaxWidthWrapper.astro";

const services = [
  {
    id: "01",
    icon: LayoutDashboard,
    title: "Dirección Administrativa",
    description:
      "Actua como brújula que asegura el rumbo, proyecta la visión empresarial, facilita la toma de decisiones y el uso eficiente de los recursos garantizando el éxito operativo.",
    features: [
      "Planeación estratégica",
      "Gestión comercial",
      "Gestión documental",
    ],
    accent: "#00b398",
  },
  {
    id: "02",
    icon: TrendingUp,
    title: "Dirección Contable y Financiera",
    description:
      "Planifica, organiza, supervisa y controla las operaciones financieras, garantizando el cumplimiento fiscal.",
    features: [
      "Estrategia tributaria",
      "Valoración de empresas",
      "Gestión contable",
      "Revisoría fiscal",
    ],
    accent: "#17b0cf",
  },
  {
    id: "03",
    icon: Rocket,
    title: "Dirección Gestión de Proyectos",
    description:
      "Orientamos tus ideas hacia la realización; mediante la planificación, ejecución y supervisión del proyecto con objetivos estratégicos y uso eficiente de los recursos.",
    features: [
      "Transformación digital",
      "Marketing digital",
      "Desarrollo web",
      "Fondos de inversión",
    ],
    accent: "#308ce8",
  },
  {
    id: "04",
    icon: Users,
    title: "Dirección de Talento Humano",
    description:
      "Coordina la gestión integral del personal, alineando el capital humano con los objetivos estratégicos de la empresa para mejorar la productividad, el clima laboral y la competitividad.",
    features: [
      "Contratación laboral",
      "Evaluación de desempeño",
      "Desarrollo organizacional",
      "Capacitación",
      "Gestión de seguridad y salud en el trabajo",
    ],
    accent: "#33cc80",
  },
  {
    id: "05",
    icon: Scale,
    title: "Dirección Jurídica",
    description:
      "Asesora, gestiona y defiende los intereses legales de las empresas.",
    features: [
      "Registro de marcas",
      "Disolución",
      "Derechos de autor",
      "Protección de propiedad industrial",
    ],
    accent: "#00b398",
  },
];
---

<section class="services-section py-24 md:py-32" id="servicios">
  <MaxWidthWrapper>
    <!-- Section header -->
    <div class="services-header mb-16 md:mb-20">
      <div class="mb-4 flex items-center gap-3">
        <span
          class="h-px w-8 bg-primary"
        ></span>
        <span
          class="font-mono text-sm font-semibold uppercase tracking-widest text-primary"
        >
          Nuestros Servicios
        </span>
     
      </div>
      <div
        class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
      >
        <h2
          class="services-heading max-w-xl text-4xl leading-tight font-semibold tracking-tight text-foreground md:text-5xl"
        >
          Soluciones Empresariales
          <em class="services-em not-italic text-primary">Integrales</em>
        </h2>
        <p
          class="max-w-sm text-base leading-relaxed text-muted-foreground md:text-right"
        >
          Ofrecemos un portafolio completo de servicios especializados para que
          tu negocio crezca de manera rentable y sostenible.
        </p>
      </div>
    </div>

    <!-- Service cards: flex-wrap so orphan cards centre automatically -->
    <div class="services-grid flex flex-wrap justify-center gap-5">
      {
        services.map((service, i) => {
          const Icon = service.icon;
          return (
            <article
              class:list={[
                "service-card group relative flex w-full flex-col overflow-hidden rounded-2xl border border-border bg-card p-7 transition-all duration-500 sm:w-[calc(50%-10px)] lg:w-[calc(33.333%-14px)]",
              ]}
              style={`--card-accent: ${service.accent}; animation-delay: ${i * 80}ms`}
            >
              <!-- Background number watermark -->
              <span
                aria-hidden="true"
                class="absolute right-5 top-3 select-none font-mono text-[5rem] font-bold leading-none text-foreground/[0.035] transition-all duration-500 group-hover:text-foreground/5.5"
              >
                {service.id}
              </span>

              <!-- Accent line at top -->
              <div
                class="mb-6 h-0.5 w-10 rounded-full transition-all duration-500 group-hover:w-16"
                style={`background: ${service.accent}`}
              />

              <!-- Icon -->
              <div
                class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl transition-transform duration-500 group-hover:scale-110"
                style={`background: color-mix(in srgb, ${service.accent} 12%, transparent)`}
              >
                <Icon
                  class="h-6 w-6"
                  style={`color: ${service.accent}`}
                />
              </div>

              <!-- Content -->
              <h3 class="mb-3 text-lg font-semibold leading-snug text-foreground">
                {service.title}
              </h3>
              <p class="mb-6 text-sm leading-relaxed text-muted-foreground">
                {service.description}
              </p>

              <!-- Feature list -->
              <ul class="mb-7 flex flex-1 flex-col gap-2">
                {service.features.map((feat) => (
                  <li class="flex items-start gap-2 text-sm text-foreground/75">
                    <CheckCircle2
                      class="mt-0.5 h-4 w-4 shrink-0"
                      style={`color: ${service.accent}`}
                    />
                    <span>{feat}</span>
                  </li>
                ))}
              </ul>

              <!-- CTA link -->
              <a
                href="#"
                class="group/link mt-auto inline-flex items-center gap-1.5 text-sm font-semibold transition-all duration-300"
                style={`color: ${service.accent}`}
              >
                Saber Más
                <ChevronRight class="h-4 w-4 transition-transform duration-300 group-hover/link:translate-x-1" />
              </a>

              <!-- Hover glow border -->
              <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 ring-1 transition-opacity duration-500 group-hover:opacity-100"
                style={`box-shadow: inset 0 0 0 1px ${service.accent}40; ring-color: ${service.accent}`}
              />
            </article>
          );
        })
      }
    </div>

    <!-- Bottom CTA -->
    <div class="services-cta mt-14 flex justify-center">
      <a
        href="#"
        class="cta-btn group inline-flex items-center gap-2.5 rounded-full border border-primary/30 bg-primary/5 px-7 py-3.5 text-sm font-semibold text-primary transition-all duration-300 hover:border-primary/60 hover:bg-primary hover:text-primary-foreground"
      >
        Ver Todos los Servicios
        <ArrowRight
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
        />
      </a>
    </div>
  </MaxWidthWrapper>
</section>

<style>
  .services-section {
    background:
      radial-gradient(
        ellipse 80% 50% at 50% -10%,
        color-mix(in srgb, var(--primary) 8%, transparent),
        transparent
      ),
      var(--background);
  }

  /* Scroll-reveal animations */
  .service-card {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s ease,
      border-color 0.4s ease;
  }

  .service-card.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .service-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--card-accent) 30%, var(--border));
    transform: translateY(-3px);
  }

  .services-header {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .services-header.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .services-cta {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.5s ease 0.3s,
      transform 0.5s ease 0.3s;
  }

  .services-cta.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 },
  );

  document
    .querySelectorAll(".service-card, .services-header, .services-cta")
    .forEach((el) => observer.observe(el));
</script>
