---
const categories = [
    { id: "all", name: "Todos los Servicios" },
    { id: "administracion", name: "Administración" },
    { id: "financiera", name: "Financiera" },
    { id: "proyectos", name: "Proyectos" },
    { id: "talento-humano", name: "Talento Humano" },
    { id: "juridica", name: "Jurídica" },
    { id: "digital", name: "Digital" },
    { id: "facturacion", name: "Facturación" },
];
---

<section
    class="bg-background relative z-20 -mt-8 rounded-t-3xl border-b-2 border-b-slate-200 py-8"
>
    <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-6 w-full max-w-4xl">
            <div class="flex flex-wrap items-center justify-center gap-3">
                {
                    categories.map((category, index) => (
                        <button
                            type="button"
                            data-filter={
                                category.id === "all" ? "all" : category.name
                            }
                            class={`filter-btn rounded-full border px-6 py-2.5 text-sm font-semibold shadow-xs transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md ${
                                index === 0
                                    ? "bg-primary border-transparent text-white"
                                    : "bg-card text-foreground border-border hover:border-primary/50 hover:bg-primary/5"
                            }`}
                        >
                            {category.name}
                        </button>
                    ))
                }
            </div>
        </div>

        <div
            id="filter-counter"
            class="text-muted-foreground mt-4 text-center text-sm"
        >
            Cargando servicios...
        </div>
    </div>
</section>

<script>
    const setupFilters = () => {
        const buttons = document.querySelectorAll(".filter-btn");
        const cards = document.querySelectorAll(
            ".service-card",
        ) as NodeListOf<HTMLElement>;
        const counter = document.getElementById("filter-counter");

        const updateCounter = () => {
            if (!counter) return;
            const visibleCards = document.querySelectorAll(
                ".service-card:not(.hidden)",
            ).length;
            counter.textContent = `${visibleCards} ${visibleCards === 1 ? "servicio encontrado" : "servicios encontrados"}`;
        };

        // Initial counter update
        updateCounter();

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const filterValue = btn.getAttribute("data-filter");

                // Update button styles
                buttons.forEach((b) => {
                    b.classList.remove(
                        "bg-primary",
                        "text-white",
                        "border-transparent",
                    );
                    b.classList.add(
                        "bg-card",
                        "text-foreground",
                        "border-border",
                        "hover:border-primary/50",
                        "hover:bg-primary/5",
                    );
                });

                btn.classList.remove(
                    "bg-card",
                    "text-foreground",
                    "border-border",
                    "hover:border-primary/50",
                    "hover:bg-primary/5",
                );
                btn.classList.add(
                    "bg-primary",
                    "text-white",
                    "border-transparent",
                );

                cards.forEach((card) => {
                    const cardCategory = card.getAttribute("data-category");

                    if (filterValue === "all" || cardCategory === filterValue) {
                        card.classList.remove("hidden");
                    } else {
                        card.classList.add("hidden");
                    }
                });

                updateCounter();
            });
        });
    };

    // Run setup immediately and on view transitions
    setupFilters();
    document.addEventListener("astro:after-swap", setupFilters);
</script>
