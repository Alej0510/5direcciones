---
import MaxWidthWrapper from "../MaxWidthWrapper.astro";
---

<section class="bg-background relative py-20">
    <MaxWidthWrapper>
        <div class="mx-auto mb-16 max-w-3xl text-center">
            <span
                class="border-primary/20 bg-primary/10 text-primary mb-4 inline-block rounded-full border px-3 py-1 text-sm font-semibold tracking-wider"
            >
                Nuestro Proceso
            </span>
            <h2
                class="text-foreground mb-6 text-3xl font-bold tracking-tight sm:text-4xl"
            >
                Cómo Trabajamos Contigo
            </h2>
        </div>

        <div class="relative mx-auto max-w-5xl">
            <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
                {
                    [
                        {
                            step: "01",
                            title: "Diagnóstico",
                            description:
                                "Analizamos tu empresa para identificar oportunidades de mejora.",
                        },
                        {
                            step: "02",
                            title: "Propuesta",
                            description:
                                "Diseñamos una solución personalizada para tus necesidades específicas.",
                        },
                        {
                            step: "03",
                            title: "Implementación",
                            description:
                                "Ejecutamos el plan con nuestro equipo de especialistas.",
                        },
                        {
                            step: "04",
                            title: "Seguimiento",
                            description:
                                "Monitoreamos resultados y optimizamos continuamente.",
                        },
                    ].map((item, index) => (
                        <div class="group relative flex flex-col items-center text-center">
                            <div class="bg-primary group-hover:shadow-primary/30 relative z-10 mb-6 flex h-16 w-16 items-center justify-center rounded-full border-4 border-white text-xl font-bold text-white shadow-sm transition-all duration-300 group-hover:-translate-y-2 group-hover:shadow-lg">
                                {item.step}
                            </div>
                            <h3 class="text-foreground group-hover:text-primary mb-3 text-xl font-bold transition-colors duration-300">
                                {item.title}
                            </h3>
                            <p class="text-muted-foreground group-hover:text-foreground/80 text-sm transition-colors duration-300">
                                {item.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </MaxWidthWrapper>
</section>
