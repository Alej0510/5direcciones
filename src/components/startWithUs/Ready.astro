---
import MaxWidthWrapper from "../MaxWidthWrapper.astro";
import { BookOpen } from "@lucide/astro";
---

<!-- Bottom CTA Section -->
<section
    class="relative overflow-hidden bg-linear-to-r from-[#00b398] to-[#17b0cf] py-24 md:py-32"
>
    <MaxWidthWrapper class="relative z-10">
        <div class="mx-auto max-w-3xl text-center">
            <h2
                class="mb-6 text-3xl font-bold tracking-tight text-white md:text-4xl lg:text-5xl"
            >
                ¿Listo para Comenzar tu Propio Negocio?
            </h2>
            <p
                class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-white/90 md:text-xl"
            >
                No dejes pasar esta oportunidad única de emprender con el
                respaldo de una empresa consolidada y exitosa.
            </p>

            <div
                class="flex flex-col items-center justify-center gap-4 sm:flex-row"
            >
                <a
                    href="https://wa.me/573013936616?text=Hola, quiero emprender con 5 Direcciones"
                    class="btn text-primary h-12 gap-2 rounded-xl bg-white px-8 text-base font-semibold shadow-lg transition-all hover:-translate-y-1 hover:bg-white/90 hover:shadow-xl"
                >
                    Comenzar Ahora
                    <BookOpen class="h-4 w-4" />
                </a>
            </div>
        </div>
    </MaxWidthWrapper>
</section>
