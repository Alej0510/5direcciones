---
import MaxWidthWrapper from "../MaxWidthWrapper.astro";
import {
    Handshake,
    Lightbulb,
    Users,
    BarChart3,
    Rocket,
    ArrowRight,
    Star,
} from "@lucide/astro";

const supportItems = [
    {
        title: "Gerente de Cuenta Dedicado",
        description:
            "Un profesional experimentado te acompañará y guiará en cada paso de tu crecimiento.",
        icon: Handshake,
    },
    {
        title: "Capacitación Continua",
        description:
            "Acceso exclusivo a actualizaciones constantes sobre productos y técnicas de venta de vanguardia.",
        icon: Lightbulb,
    },
    {
        title: "Comunidad de Representantes",
        description:
            "Conéctate con una red de apoyo activa formada por los representantes más exitosos del país.",
        icon: Users,
    },
    {
        title: "Herramientas de Gestión",
        description:
            "CRM avanzado y herramientas digitales diseñadas para gestionar tus ventas con máxima eficiencia.",
        icon: BarChart3,
    },
];
---

<section id="support" class="bg-background relative overflow-hidden py-24">
    <!-- Subtle Background Decorations -->
    <div class="pointer-events-none absolute inset-0 z-0">
        <div
            class="bg-primary/5 absolute top-[20%] right-[-10%] h-[40%] w-[40%] rounded-full blur-[140px]"
        >
        </div>
        <div
            class="bg-secondary/30 absolute bottom-[10%] left-[-10%] h-[35%] w-[35%] rounded-full blur-[120px]"
        >
        </div>
    </div>

    <MaxWidthWrapper class="relative z-10">
        <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
            <!-- Left Content -->
            <div class="animate-fade-in-left">
                <span
                    class="bg-secondary/50 text-secondary-foreground border-primary/20 mb-6 inline-flex items-center rounded-full border px-4 py-1.5 text-xs font-bold tracking-wider uppercase backdrop-blur-sm"
                >
                    Soporte y Acompañamiento
                </span>
                <h2
                    class="text-foreground mb-8 text-4xl leading-[1.1] font-black tracking-tight md:text-5xl lg:text-6xl"
                >
                    No Estarás Solo en este <span
                        class="text-primary font-serif italic">Camino</span
                    >
                </h2>

                <div class="mb-12 space-y-8">
                    {
                        supportItems.map((item, index) => (
                            <div
                                class="group animate-on-scroll flex items-start gap-6"
                                style={`animation-delay: ${index * 150}ms`}
                            >
                                <div class="border-border/50 group-hover:bg-primary group-hover:border-primary flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border bg-white shadow-sm transition-all duration-300">
                                    <item.icon class="text-primary h-6 w-6 transition-colors group-hover:text-white" />
                                </div>
                                <div class="grow">
                                    <h3 class="text-foreground group-hover:text-primary mb-2 text-xl font-bold transition-colors">
                                        {item.title}
                                    </h3>
                                    <p class="text-muted-foreground/90 leading-relaxed font-medium">
                                        {item.description}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <a
                    href="#contact"
                    class="group border-border/80 text-foreground hover:border-primary/30 inline-flex items-center justify-center gap-3 rounded-2xl border bg-white px-10 py-4 font-bold shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
                >
                    Agendar Reunión Informativa
                    <ArrowRight
                        class="text-primary h-5 w-5 transition-transform group-hover:translate-x-1"
                    />
                </a>
            </div>

            <!-- Right Visual Component -->
            <div
                class="animate-fade-in-right relative flex justify-center lg:justify-end"
            >
                <!-- Main Circular Element -->
                <div
                    class="relative flex h-80 w-80 items-center justify-center md:h-[450px] md:w-[450px]"
                >
                    <!-- Pulsing Rings -->
                    <div
                        class="border-primary/10 absolute inset-0 animate-ping rounded-full border-2 opacity-20"
                    >
                    </div>
                    <div
                        class="border-primary/5 absolute inset-8 animate-ping rounded-full border-2 opacity-10"
                        style="animation-delay: 1s"
                    >
                    </div>

                    <!-- Glassmorphic Background -->
                    <div
                        class="from-primary to-primary shadow-primary/30 absolute inset-4 transform rounded-full bg-linear-to-br via-[#17b0cf] shadow-2xl transition-transform duration-700 group-hover:scale-105"
                    >
                    </div>

                    <!-- Content -->
                    <div class="relative z-10 p-8 text-center text-white">
                        <div
                            class="animate-bounce-slow mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full border border-white/20 bg-white/20 shadow-inner backdrop-blur-md md:h-32 md:w-32"
                        >
                            <Rocket
                                class="h-12 w-12 text-white md:h-16 md:w-16"
                                stroke-width={1.5}
                            />
                        </div>
                        <h3
                            class="mb-2 text-3xl font-black tracking-tight uppercase drop-shadow-lg md:text-5xl"
                        >
                            Tu Futuro
                        </h3>
                        <p
                            class="text-xl font-bold italic opacity-90 drop-shadow-md md:text-2xl"
                        >
                            Te Espera!
                        </p>
                    </div>

                    <!-- Floating Achievement elements -->
                    <div
                        class="border-border/50 animate-bounce-slow absolute top-10 right-10 flex h-16 w-16 items-center justify-center rounded-2xl border bg-white shadow-xl"
                        style="animation-delay: 0.5s"
                    >
                        <div class="text-primary text-xl font-black">100%</div>
                    </div>
                    <div
                        class="border-border/50 animate-bounce-slow absolute bottom-20 -left-10 flex h-20 w-20 items-center justify-center rounded-[2rem] border bg-white shadow-xl"
                        style="animation-delay: 1.2s"
                    >
                        <Star class="h-8 w-8 fill-orange-400 text-orange-400" />
                    </div>
                </div>
            </div>
        </div>
    </MaxWidthWrapper>
</section>

<style>
    @keyframes fade-in-left {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    @keyframes fade-in-right {
        from {
            opacity: 0;
            transform: scale(0.9) rotate(-5deg);
        }
        to {
            opacity: 1;
            transform: scale(1) rotate(0);
        }
    }
    @keyframes bounce-slow {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-20px);
        }
    }
    .animate-fade-in-left {
        animation: fade-in-left 1s ease-out forwards;
    }
    .animate-fade-in-right {
        animation: fade-in-right 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-bounce-slow {
        animation: bounce-slow 4s ease-in-out infinite;
    }

    .animate-on-scroll {
        opacity: 0;
        transform: translateY(20px);
        animation: slide-up 0.8s ease-out forwards;
    }

    @keyframes slide-up {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
