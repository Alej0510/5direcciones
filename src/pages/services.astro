---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ServicesHero from "../components/services/ServicesHero.astro";
import Ready from "../components/services/Ready.astro";
import ServiceCard from "@/components/services/ServiceCard.astro";
import Process from "@/components/services/Process.astro";
import Ecosystem from "@/components/services/Ecosystem.astro";
import FilterButtons from "@/components/services/FilterButtons.astro";
---

<Layout>
    <Header />
    <ServicesHero />
    <section class="bg-background relative z-20 -mt-8 rounded-t-3xl py-12">
        <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
            <FilterButtons />
            <div class="text-muted-foreground mt-4 text-center text-sm">
                0 servicios encontrados
            </div>
        </div>
    </section>
    <ServiceCard />
    <Ecosystem />
    <Process />
    <Ready />
    <Footer />
</Layout>
